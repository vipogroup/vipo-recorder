<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
  xmlns:app="http://schemas.android.com/apk/res-auto"
  android:layout_width="match_parent"
  android:layout_height="match_parent"
  android:background="@drawable/kid_bg"
  android:orientation="vertical"
  android:padding="16dp">

  <TextView
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center"
    android:text="@string/parent_settings_title"
    android:textColor="@android:color/white"
    android:textSize="22sp"
    android:textStyle="bold"
    android:paddingBottom="4dp" />

  <TextView
    android:id="@+id/txtDeviceOwner"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center"
    android:textColor="#80FFFFFF"
    android:textSize="13sp"
    android:paddingBottom="8dp" />

  <com.google.android.material.textfield.TextInputLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    app:hintTextColor="#AAAAAA"
    app:boxStrokeColor="#2196F3"
    android:theme="@style/ThemeOverlay.Material3.TextInputEditText.OutlinedBox">

    <com.google.android.material.textfield.TextInputEditText
      android:id="@+id/editKidScreenName"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:hint="@string/kid_screen_name_hint"
      android:textColor="@android:color/white"
      android:textSize="15sp"
      android:inputType="text"
      android:maxLength="30" />
  </com.google.android.material.textfield.TextInputLayout>

  <androidx.recyclerview.widget.RecyclerView
    android:id="@+id/rvApps"
    android:layout_width="match_parent"
    android:layout_height="0dp"
    android:layout_weight="1"
    android:clipToPadding="false"
    android:paddingTop="4dp"
    android:paddingBottom="4dp" />

  <ScrollView
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="8dp"
    android:maxHeight="240dp">

    <LinearLayout
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:orientation="vertical">

      <com.google.android.material.button.MaterialButton
        android:id="@+id/btnRecordPerms"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="@drawable/btn_primary_bg"
        android:textColor="@android:color/white"
        android:textSize="15sp"
        android:insetTop="0dp"
        android:insetBottom="0dp"
        app:backgroundTint="@null"
        app:cornerRadius="12dp"
        android:text="הרשאות הקלטה" />

      <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSave"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="6dp"
        android:background="@drawable/btn_primary_bg"
        android:textColor="@android:color/white"
        android:textSize="15sp"
        android:insetTop="0dp"
        android:insetBottom="0dp"
        app:backgroundTint="@null"
        app:cornerRadius="12dp"
        android:text="@string/save" />

      <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:orientation="horizontal"
        android:weightSum="2">

        <com.google.android.material.button.MaterialButton
          android:id="@+id/btnActivate"
          android:layout_width="0dp"
          android:layout_height="48dp"
          android:layout_weight="1"
          android:layout_marginEnd="3dp"
          android:background="@drawable/btn_primary_bg"
          android:textColor="@android:color/white"
          android:textSize="13sp"
          android:insetTop="0dp"
          android:insetBottom="0dp"
          app:backgroundTint="@null"
          app:cornerRadius="12dp"
          android:text="@string/activate_kid_mode" />

        <com.google.android.material.button.MaterialButton
          android:id="@+id/btnDeactivate"
          android:layout_width="0dp"
          android:layout_height="48dp"
          android:layout_weight="1"
          android:layout_marginStart="3dp"
          android:background="@drawable/btn_secondary_bg"
          android:textColor="#FFCCCCCC"
          android:textSize="13sp"
          android:insetTop="0dp"
          android:insetBottom="0dp"
          app:backgroundTint="@null"
          app:cornerRadius="12dp"
          android:text="@string/deactivate_kid_mode" />
      </LinearLayout>

      <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:orientation="horizontal"
        android:weightSum="2">

        <com.google.android.material.button.MaterialButton
          android:id="@+id/btnChangePin"
          android:layout_width="0dp"
          android:layout_height="48dp"
          android:layout_weight="1"
          android:layout_marginEnd="3dp"
          android:background="@drawable/btn_secondary_bg"
          android:textColor="#FFCCCCCC"
          android:textSize="13sp"
          android:insetTop="0dp"
          android:insetBottom="0dp"
          app:backgroundTint="@null"
          app:cornerRadius="12dp"
          android:text="@string/change_pin" />

        <com.google.android.material.button.MaterialButton
          android:id="@+id/btnChooseNormalHome"
          android:layout_width="0dp"
          android:layout_height="48dp"
          android:layout_weight="1"
          android:layout_marginStart="3dp"
          android:background="@drawable/btn_secondary_bg"
          android:textColor="#FFCCCCCC"
          android:textSize="13sp"
          android:insetTop="0dp"
          android:insetBottom="0dp"
          app:backgroundTint="@null"
          app:cornerRadius="12dp"
          android:text="@string/choose_normal_home" />
      </LinearLayout>

      <com.google.android.material.button.MaterialButton
        android:id="@+id/btnBack"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:layout_marginTop="6dp"
        android:background="@drawable/btn_secondary_bg"
        android:textColor="#FFAAAAAA"
        android:textSize="14sp"
        android:insetTop="0dp"
        android:insetBottom="0dp"
        app:backgroundTint="@null"
        app:cornerRadius="12dp"
        android:text="@string/back" />

    </LinearLayout>
  </ScrollView>

</LinearLayout>
