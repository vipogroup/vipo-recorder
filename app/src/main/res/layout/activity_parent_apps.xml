<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
  android:layout_width="match_parent"
  android:layout_height="match_parent"
  android:background="@drawable/recorder_bg"
  android:orientation="vertical"
  android:padding="16dp">

  <TextView
    android:id="@+id/txtTitle"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center"
    android:text="@string/parental_apps_title"
    android:textColor="@android:color/white"
    android:textSize="22sp"
    android:textStyle="bold"
    android:paddingBottom="4dp" />

  <TextView
    android:id="@+id/txtDeviceOwner"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center"
    android:text="@string/parental_device_owner_unknown"
    android:textColor="#80FFFFFF"
    android:textSize="13sp"
    android:paddingBottom="8dp" />

  <ListView
    android:id="@+id/listApps"
    android:layout_width="match_parent"
    android:layout_height="0dp"
    android:layout_weight="1"
    android:divider="@android:color/transparent"
    android:dividerHeight="4dp" />

  <Button
    android:id="@+id/btnRecordPerms"
    android:layout_width="match_parent"
    android:layout_height="48dp"
    android:layout_marginTop="6dp"
    android:background="@drawable/btn_primary_bg"
    android:textColor="@android:color/white"
    android:textSize="15sp"
    android:textAllCaps="false"
    android:text="הרשאות הקלטה" />

  <Button
    android:id="@+id/btnSave"
    android:layout_width="match_parent"
    android:layout_height="48dp"
    android:layout_marginTop="6dp"
    android:background="@drawable/btn_primary_bg"
    android:textColor="@android:color/white"
    android:textSize="15sp"
    android:textAllCaps="false"
    android:text="@string/save" />

  <Button
    android:id="@+id/btnActivate"
    android:layout_width="match_parent"
    android:layout_height="48dp"
    android:layout_marginTop="6dp"
    android:background="@drawable/btn_record_bg"
    android:textColor="@android:color/white"
    android:textSize="15sp"
    android:textAllCaps="false"
    android:text="@string/parental_activate_child_mode" />

  <Button
    android:id="@+id/btnDeactivate"
    android:layout_width="match_parent"
    android:layout_height="44dp"
    android:layout_marginTop="6dp"
    android:background="@drawable/btn_secondary_bg"
    android:textColor="#FFAAAAAA"
    android:textSize="14sp"
    android:textAllCaps="false"
    android:text="@string/parental_deactivate_child_mode" />

  <Button
    android:id="@+id/btnBack"
    android:layout_width="match_parent"
    android:layout_height="44dp"
    android:layout_marginTop="6dp"
    android:background="@drawable/btn_secondary_bg"
    android:textColor="#FFAAAAAA"
    android:textSize="14sp"
    android:textAllCaps="false"
    android:text="@string/back" />

</LinearLayout>
