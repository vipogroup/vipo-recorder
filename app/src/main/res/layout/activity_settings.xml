<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
  android:layout_width="match_parent"
  android:layout_height="match_parent"
  android:background="@drawable/recorder_bg"
  android:fillViewport="true">

  <LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
      android:id="@+id/txtTitle"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:gravity="center"
      android:text="@string/settings"
      android:textColor="@android:color/white"
      android:textSize="22sp"
      android:textStyle="bold"
      android:paddingBottom="16dp" />

    <LinearLayout
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:background="@drawable/card_bg"
      android:orientation="vertical"
      android:padding="16dp">

      <TextView
        android:id="@+id/txtResolutionTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/recording_resolution"
        android:textColor="#AAAAAA"
        android:textSize="14sp" />

      <RadioGroup
        android:id="@+id/radioResolution"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:orientation="vertical">

        <RadioButton
          android:id="@+id/radioRes100"
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:textColor="@android:color/white"
          android:text="@string/resolution_100" />

        <RadioButton
          android:id="@+id/radioRes75"
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:layout_marginTop="6dp"
          android:textColor="@android:color/white"
          android:text="@string/resolution_75" />

        <RadioButton
          android:id="@+id/radioRes50"
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:layout_marginTop="6dp"
          android:textColor="@android:color/white"
          android:text="@string/resolution_50" />

      </RadioGroup>

      <TextView
        android:id="@+id/txtNote"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="@string/resolution_note"
        android:textColor="#60FFFFFF"
        android:textSize="12sp" />

    </LinearLayout>

    <LinearLayout
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginTop="14dp"
      android:background="@drawable/card_bg"
      android:orientation="vertical"
      android:padding="16dp">

      <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="איכות הקלטה"
        android:textColor="#AAAAAA"
        android:textSize="14sp" />

      <RadioGroup
        android:id="@+id/radioQuality"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:orientation="vertical">

        <RadioButton
          android:id="@+id/radioQualityLow"
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:textColor="@android:color/white"
          android:text="נמוך — ~7MB/דקה (מומלץ לשליחה בוואצאפ)" />

        <RadioButton
          android:id="@+id/radioQualityMedium"
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:layout_marginTop="6dp"
          android:textColor="@android:color/white"
          android:text="בינוני — ~15MB/דקה (ברירת מחדל)" />

        <RadioButton
          android:id="@+id/radioQualityHigh"
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:layout_marginTop="6dp"
          android:textColor="@android:color/white"
          android:text="גבוה — ~60MB/דקה (מסך מלא)" />

      </RadioGroup>

    </LinearLayout>

    <LinearLayout
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginTop="14dp"
      android:background="@drawable/card_bg"
      android:orientation="vertical"
      android:padding="16dp">

      <TextView
        android:id="@+id/txtUpdateUrlTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/update_url"
        android:textColor="#AAAAAA"
        android:textSize="14sp" />

      <EditText
        android:id="@+id/editUpdateUrl"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:hint="@string/update_url_hint"
        android:textColor="@android:color/white"
        android:textColorHint="#60FFFFFF"
        android:inputType="textUri"
        android:maxLines="1" />

      <TextView
        android:id="@+id/txtUpdateUrlNote"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="@string/update_url_note"
        android:textColor="#60FFFFFF"
        android:textSize="12sp" />

    </LinearLayout>

    <Button
      android:id="@+id/btnSaveUpdateUrl"
      android:layout_width="match_parent"
      android:layout_height="48dp"
      android:layout_marginTop="16dp"
      android:background="@drawable/btn_primary_bg"
      android:textColor="@android:color/white"
      android:textSize="15sp"
      android:textAllCaps="false"
      android:text="@string/save" />

    <Button
      android:id="@+id/btnBack"
      android:layout_width="match_parent"
      android:layout_height="44dp"
      android:layout_marginTop="8dp"
      android:background="@drawable/btn_secondary_bg"
      android:textColor="#FFAAAAAA"
      android:textSize="14sp"
      android:textAllCaps="false"
      android:text="@string/back" />

  </LinearLayout>

</ScrollView>
